<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:macros="sap.fe.macros">
	<VBox id="VBox" core:require="{ handler: 'com/invoiceapp/manageinvoice/ext/fragment/InvoiceSummary'}">
       <!-- ═══════════════════════════════════════
             STATS DISPLAY
             Bound to a local JSONModel named 'stats'
             Set on this VBox by the JS handler
             on first button click
        ════════════════════════════════════════ -->
        <Title text="Invoice Statistics"
               class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"/>

        <HBox justifyContent="SpaceAround"
              class="sapUiSmallMarginTop sapUiSmallMarginBottom">

            <VBox alignItems="Center" class="sapUiSmallMarginBeginEnd">
                <ObjectNumber number="{stats>/totalItems}"
                              unit="Items"
                              emphasized="true"/>
                <Label text="Total Line Items"
                       class="sapUiTinyMarginTop"/>
            </VBox>

            <VBox alignItems="Center" class="sapUiSmallMarginBeginEnd">
                <ObjectNumber number="{stats>/totalAmount}"
                              unit="INR"
                              emphasized="true"/>
                <Label text="Total Amount"
                       class="sapUiTinyMarginTop"/>
            </VBox>

            <VBox alignItems="Center" class="sapUiSmallMarginBeginEnd">
                <ObjectNumber number="{stats>/highestAmount}"
                              unit="INR"
                              state="Warning"/>
                <Label text="Highest Item"
                       class="sapUiTinyMarginTop"/>
            </VBox>

        </HBox>

        <!-- ═══════════════════════════════════════
             LOAD BUTTON
             Must be a DIRECT child of the VBox above.
             This is intentional — explained below.
        ════════════════════════════════════════ -->
        <Button text="Load Stats"
                icon="sap-icon://refresh"
                type="Emphasized"
                press="handler.onLoadStats"
                class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom"/>

       <!-- ══════════════════════════════════════
             QUICK ADD FORM (Step 4 — NEW)
             Inputs are two-way bound to a 'form'
             JSONModel set on this VBox.
        ═══════════════════════════════════════ -->
        <Title text="Quick Add Line Item"
               class="sapUiSmallMarginBeginEnd sapUiMediumMarginTop"/>
        <Label text="Description" required="true"
               class="sapUiSmallMarginBeginEnd sapUiTinyMarginTop"/>
        <Input value="{form>/description}"
               placeholder="e.g. Dell Monitor 24 inch"
               class="sapUiSmallMarginBeginEnd"/>

        <Label text="Quantity" required="true"
               class="sapUiSmallMarginBeginEnd sapUiTinyMarginTop"/>
        <Input value="{form>/quantity}"
               type="Number"
               placeholder="1"
               class="sapUiSmallMarginBeginEnd"/>

        <Label text="Unit Price (INR)" required="true"
               class="sapUiSmallMarginBeginEnd sapUiTinyMarginTop"/>
        <Input value="{form>/unitPrice}"
               type="Number"
               placeholder="0.00"
               class="sapUiSmallMarginBeginEnd"/>

         <!-- Live calculated amount — updates as user types -->
        <Label text="Calculated Amount"
               class="sapUiSmallMarginBeginEnd sapUiTinyMarginTop"/>
        <ObjectNumber number="{form>/calculatedAmount}"
                      unit="INR"
                      emphasized="true"
                      state="Success"
                      class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom"/>

        <HBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop
                     sapUiSmallMarginBottom">
            <Button text="Clear"
                    icon="sap-icon://clear-all"
                    press="handler.onClearForm"
                    class="sapUiSmallMarginEnd"/>
            <Button text="Add Line Item"
                    icon="sap-icon://add"
                    type="Emphasized"
                    press="handler.onAddLineItem"/>
        </HBox>
       </VBox>
</core:FragmentDefinition>